# Copy this file to .env and adjust values for your node.
# docker compose will automatically load .env from the same directory.

# --- Ports ---
OLLAMA_PORT=11434
WEBUI_PORT=3000

# --- GPU ---
# Number of GPUs to expose to Ollama. Use 1 for single-GPU nodes.
GPU_COUNT=1

# --- Model Storage ---
# Leave empty to use a named Docker volume (recommended for single-node).
# Set to an absolute path (e.g. /mnt/models) to use a host-mounted disk.
MODELS_PATH=

# --- Ollama Tuning ---
# How long a loaded model stays in VRAM when idle.
# Use -1 to never unload (recommended for single-user homelab).
# Use 5m for shared/intermittent use.
OLLAMA_KEEP_ALIVE=5m

# Max parallel inference requests. 1 is optimal for single-user.
# Increase if serving multiple users or apps simultaneously.
OLLAMA_NUM_PARALLEL=1

# --- Multi-node (used by docker-compose.multi.yml only) ---
# Semicolon-separated list of Ollama endpoints on your other nodes.
# Example: http://192.168.1.10:11434;http://192.168.1.11:11434
OLLAMA_NODES=
